# Thai Ticket Major credentials
TTM_USERNAME=your_email@example.com
TTM_PASSWORD=your_password

# Target concert (use URL or name)
CONCERT_URL=https://www.thaiticketmajor.com/concert/your-concert
CONCERT_NAME=

# Ticket preferences
NUM_TICKETS=2
PREFERRED_DATES=2024-12-01,2024-12-02
PREFERRED_ZONES=FLOOR,VIP,A,B,C

# Optional: Proxy (one per line in proxy.txt, or comma-separated here)
PROXY_LIST=

# Optional: 2Captcha API key for auto captcha solving
CAPTCHA_API_KEY=

# Bot behavior
HEADLESS=false
CHECK_INTERVAL=3
MAX_RETRIES=5

# Notifications (optional)
WEBHOOK_URL=
NOTIFICATION_SOUND=true

# Buyer info (for auto-fill)
BUYER_FIRST_NAME=
BUYER_LAST_NAME=
BUYER_EMAIL=
BUYER_PHONE=
BUYER_ID_CARD=
